# MediSync 환경변수 예시. 실제 값은 backend/.env 에 채우세요.
# .env 는 git 에 커밋 금지 (.gitignore 확인).

# ─── DB ───
# dev: 비워두면 SQLite 자동 (sqlite+aiosqlite:///./pharma_scheduler.db)
# prod: postgresql+asyncpg://USER:PASSWORD@HOST:5432/medisync
# DATABASE_URL=postgresql+asyncpg://medisync:CHANGE_ME@localhost:5432/medisync

# AI
ANTHROPIC_API_KEY=sk-ant-api03-...
GEMINI_API_KEY=AIza...

# Google OAuth (Google Cloud Console → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID)
GOOGLE_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxx
# 선택: 명시 안 하면 request.url_for("google_callback") 자동 사용
# GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# 세션 쿠키 서명 키 (랜덤 32+ 문자열). 운영에서는 반드시 비밀로 관리.
SESSION_SECRET_KEY=please-change-me-to-a-random-32+-char-string

# 로그인 성공 후 리다이렉트할 프론트 URL
FRONTEND_URL=http://localhost:5173

# CORS allowed origins (콤마 구분). 미설정 시 localhost:5173 + 127.0.0.1:5173 기본.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 운영 모드 ('production' 으로 설정하면 세션 쿠키 secure=true)
# ENV=development

# ─── prod 배포 시 추가 예시 ───
# DATABASE_URL=postgresql+asyncpg://medisync:비번@localhost:5432/medisync
# GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback
# FRONTEND_URL=https://your-domain.com
# CORS_ORIGINS=https://your-domain.com
# ENV=production
# SESSION_SECRET_KEY= python -c "import secrets; print(secrets.token_urlsafe(32))" 결과

# ─── Celery / Redis [optional — 베타엔 미사용] ───
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1
